# lg-tool - Environment Variables
# Copy this file to .env and fill in your values.
# Alternatively, place the .env file at ~/.lg-tool/.env

# Required for: agents, thread-create, run commands
LANGGRAPH_SERVER_URL=https://your-langgraph-server.example.com

# Required for: extract, documents commands
LANGGRAPH_POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Required only for the e2e test (test_scripts/test-e2e.ts):
# UUID of an assistant deployed on LANGGRAPH_SERVER_URL
LANGGRAPH_TEST_ASSISTANT_ID=00000000-0000-0000-0000-000000000000
