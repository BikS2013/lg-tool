# LangGraph Investigator - Environment Variables
# Copy this file to .env and fill in your values.
# Alternatively, place the .env file at ~/.langgraph-investigator/.env

# Required for: agents, thread-create, run commands
LANGGRAPH_SERVER_URL=https://your-langgraph-server.example.com

# Required for: extract command
LANGGRAPH_POSTGRES_URL=postgresql://user:password@host:5432/dbname?sslmode=require
